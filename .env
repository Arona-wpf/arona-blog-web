# 仓库或主页链接，可通过环境变量覆盖
VITE_GITHUB_URL = https://github.com/Arona-wpf
# 页脚版权主体名
VITE_OWNER = Arona-wpf
# 公安备案查询页链接（含 recordcode 参数），留空则备案文案不以链接展示。
# 示例：https://www.beian.gov.cn/portal/registerSystemInfo?recordcode=xxxxxxxx
VITE_BEIAN_URL = https://www.beian.gov.cn/portal/registerSystemInfo?recordcode=35018302000172
# 文件 CDN 地址
VITE_CDN_URL = /cdn
